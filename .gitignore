# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/

# 虚拟环境（本项目用 /tmp/vb_venv，本地若建其他 venv 也忽略）
venv/
.venv/
env/

# macOS
.DS_Store

# Xcode / Swift（.xcodeproj 由 xcodegen generate 从 project.yml 生成，不入库）
OpenVibeBoard.xcodeproj/
OpenVibeBoard.xcworkspace/
*.xcuserstate
xcuserdata/
DerivedData/
build/

# IDE / 编辑器
.vscode/
.idea/
*.swp

# 测试 / 运行产物
.playwright-mcp/
*.tmp
*.log

# 注意：以下 AI 工具目录【不忽略】，需提交以共享团队配置与 spec：
